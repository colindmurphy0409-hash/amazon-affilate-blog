---
import '@/styles/global.css';
import { getCollection } from 'astro:content';
import ProductImage from '@/components/ProductImage.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import StarRating from '@/components/StarRating.astro';
import { getAffiliateConfig, getAsinData, nicheBadgeClass, nicheLabel, nicheStripClass } from '@/lib/affiliate';

const config = getAffiliateConfig();

const pages = (await getCollection('affiliate'))
  .filter((p) => p.data.published)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const typeLabels = {
  review: 'Review',
  roundup: 'Buying guide',
  comparison: 'Comparison',
} as const;
---

<!DOCTYPE html>
<html lang="en" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="content-language" content="en-US" />
    <meta name="google" content="notranslate" />
    <meta property="og:locale" content="en_US" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{config.site_name} — Honest Product Guides</title>
    <meta name="description" content="Research-backed Amazon product reviews, roundups, and comparisons. Updated guides to help you buy with confidence." />
  </head>
  <body>
    <SiteHeader />

    <section class="relative overflow-hidden border-b border-brand-200/30 bg-mesh-hero">
      <div class="hero-blob -left-20 -top-20 h-72 w-72 bg-brand-400/30" aria-hidden="true"></div>
      <div class="hero-blob right-0 top-10 h-64 w-64 bg-coral-400/25" aria-hidden="true"></div>
      <div class="hero-blob bottom-0 left-1/3 h-56 w-56 bg-gold-400/20" aria-hidden="true"></div>

      <svg class="pointer-events-none absolute right-8 top-16 hidden h-32 w-32 text-brand-300/40 md:block" viewBox="0 0 120 120" fill="none" aria-hidden="true">
        <circle cx="60" cy="60" r="50" stroke="currentColor" stroke-width="2" stroke-dasharray="8 6" />
        <circle cx="60" cy="60" r="30" fill="currentColor" opacity="0.15" />
      </svg>
      <svg class="pointer-events-none absolute bottom-8 left-8 hidden h-24 w-24 text-coral-300/50 md:block" viewBox="0 0 80 80" aria-hidden="true">
        <path d="M40 4 L76 68 L4 68 Z" fill="currentColor" opacity="0.12" stroke="currentColor" stroke-width="1.5" />
      </svg>

      <div class="container-page relative py-16 md:py-24">
        <div class="max-w-3xl">
          <div class="flex flex-wrap gap-2">
            <span class="category-pill-beauty">Beauty</span>
            <span class="category-pill-fitness">Fitness</span>
            <span class="category-pill-home">Home</span>
          </div>
          <h1 class="mt-6 font-display text-4xl font-semibold leading-tight text-ink md:text-5xl lg:text-[3.25rem]">
            Honest guides for stuff you actually use at home
          </h1>
          <p class="mt-5 text-lg leading-relaxed text-ink-muted md:text-xl">
            {config.site_name} tests and compares products across home, beauty, and fitness —
            straight answers on what works, what does not, and who each pick is really for.
          </p>
          <p class="mt-6 inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-2 text-sm font-medium text-brand-800 ring-1 ring-brand-200/60 backdrop-blur-sm">
            <span class="h-2 w-2 rounded-full bg-brand-500"></span>
            {pages.length} published guides · Updated regularly
          </p>
        </div>
      </div>
    </section>

    <main class="container-page py-12 md:py-16">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-2xl font-semibold text-ink md:text-3xl">Latest guides</h2>
          <p class="mt-2 text-ink-muted">Reviews and comparisons we update as we add new picks.</p>
        </div>
      </div>

      {pages.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {pages.map((page) => {
            const slug = page.id.replace(/\.mdx?$/, '');
            const primaryAsin = page.data.asins[0] ? getAsinData(page.data.asins[0]) : null;
            const niche = primaryAsin?.niche;
            return (
              <a href={`/${slug}`} class="card-article group">
                <div class={nicheStripClass(niche)}></div>
                {primaryAsin && (
                  <div class="border-b border-slate-100 bg-gradient-to-br from-white to-surface-muted p-4">
                    <ProductImage
                      asin={primaryAsin.asin}
                      title={primaryAsin.title}
                      imageUrl={primaryAsin.image_url}
                      size="card"
                    />
                  </div>
                )}
                <div class="p-5">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={nicheBadgeClass(niche)}>{nicheLabel(niche)}</span>
                    <span class="badge-type">{typeLabels[page.data.type]}</span>
                  </div>
                  <h3 class="mt-3 font-display text-xl font-semibold leading-snug text-ink transition-colors group-hover:text-brand-700">
                    {page.data.title}
                  </h3>
                  <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-ink-muted">
                    {page.data.description}
                  </p>
                  {primaryAsin?.rating && (
                    <div class="mt-4">
                      <StarRating rating={primaryAsin.rating} reviewCount={primaryAsin.review_count} />
                    </div>
                  )}
                  <p class="mt-4 text-sm font-semibold text-brand-700">Read guide →</p>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="text-ink-muted">No published pages yet.</p>
      )}
    </main>

    <SiteFooter />
  </body>
</html>
