---
import { getAffiliateConfig } from '@/lib/affiliate';

const config = getAffiliateConfig();
---

<header class="site-header">
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 via-brand-600 to-sage-600 text-sm font-bold text-white shadow-md shadow-brand-500/25 transition group-hover:shadow-lg group-hover:shadow-brand-500/30">
        WL
      </span>
      <span>
        <span class="block font-display text-lg font-semibold leading-tight text-ink transition group-hover:text-brand-700">
          {config.site_name}
        </span>
        <span class="hidden text-xs text-ink-faint sm:block">{config.site_tagline}</span>
      </span>
    </a>
    <nav class="flex items-center gap-3 text-sm font-medium">
      <a href="/" class="rounded-full px-4 py-2 text-ink-muted transition hover:bg-brand-50 hover:text-brand-700">Guides</a>
      <span class="hidden h-4 w-px bg-slate-200 sm:block" aria-hidden="true"></span>
      <div class="hidden items-center gap-2 sm:flex">
        <span class="badge-beauty">Beauty</span>
        <span class="badge-fitness">Fitness</span>
        <span class="badge-home">Home</span>
      </div>
    </nav>
  </div>
</header>
