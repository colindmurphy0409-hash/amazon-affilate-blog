---
import AmazonCTA from './AmazonCTA.astro';

interface Props {
  asin: string;
  text?: string;
}

const { asin, text = 'Check price on Amazon' } = Astro.props;
---

<div class="fixed inset-x-0 bottom-0 z-50 border-t border-slate-200 bg-white/95 p-4 shadow-lift backdrop-blur md:hidden">
  <AmazonCTA asin={asin} text={text} fullWidth />
</div>
