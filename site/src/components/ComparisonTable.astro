---
import type { AsinData } from '@/lib/affiliate';
import AmazonCTA from './AmazonCTA.astro';
import ProductImage from './ProductImage.astro';
import StarRating from './StarRating.astro';

interface Props {
  asins: AsinData[];
  highlightAsin?: string;
}

const { asins, highlightAsin } = Astro.props;
---

<div class="not-prose my-10 space-y-4">
  <h2 class="font-display text-2xl font-semibold text-ink">Quick comparison</h2>

  <div class="space-y-4">
    {asins.map((asin) => (
      <div
        class:list={[
          'rounded-2xl border bg-white p-5 shadow-card',
          highlightAsin === asin.asin ? 'border-brand-300 ring-2 ring-brand-100' : 'border-slate-200',
        ]}
      >
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
          <div class="mx-auto w-full max-w-[180px] shrink-0 sm:mx-0">
            <ProductImage asin={asin.asin} title={asin.title} size="card" />
          </div>
          <div class="min-w-0 flex-1">
            {highlightAsin === asin.asin && (
              <span class="mb-2 inline-block rounded-full bg-brand-600 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
                Top pick
              </span>
            )}
            <h3 class="font-display text-lg font-semibold leading-snug text-ink">{asin.title}</h3>
            <div class="mt-2">
              <StarRating rating={asin.rating} reviewCount={asin.review_count} />
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-muted">{asin.best_for}</p>
            <p class="mt-1 text-sm font-medium text-ink">{asin.price_band}</p>
          </div>
          <div class="shrink-0 sm:w-44">
            <AmazonCTA asin={asin.asin} text="View on Amazon" variant="secondary" fullWidth />
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
