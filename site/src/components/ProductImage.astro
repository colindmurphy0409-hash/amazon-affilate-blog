---
import { buildAmazonImageUrl, buildAmazonImageFallbackUrl } from '@/lib/affiliate';

interface Props {
  asin: string;
  title: string;
  size?: 'card' | 'hero' | 'thumb';
}

const { asin, title, size = 'card' } = Astro.props;
const src = buildAmazonImageUrl(asin);
const fallback = buildAmazonImageFallbackUrl(asin);

const sizeClasses = {
  hero: 'mx-auto w-full max-w-md rounded-2xl bg-white p-6 shadow-card ring-1 ring-slate-200/80',
  card: 'aspect-[4/3] w-full overflow-hidden rounded-xl bg-white p-4 ring-1 ring-slate-200/80',
  thumb: 'h-16 w-16 shrink-0 overflow-hidden rounded-lg bg-white p-1 ring-1 ring-slate-200/80',
};

const imgClasses = {
  hero: 'h-64 w-full object-contain md:h-72',
  card: 'h-48 w-full object-contain md:h-56',
  thumb: 'h-14 w-14 object-contain',
};
---

<div class={sizeClasses[size]}>
  <img
    src={src}
    alt={title}
    width="500"
    height="500"
    loading="lazy"
    decoding="async"
    class={imgClasses[size]}
    onerror={`this.onerror=null;this.src='${fallback}';`}
  />
</div>
