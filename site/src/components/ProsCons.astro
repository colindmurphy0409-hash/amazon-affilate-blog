---
import type { AsinData } from '@/lib/affiliate';

interface Props {
  asin: AsinData;
}

const { asin } = Astro.props;
---

<div class="my-10 grid gap-5 md:grid-cols-2">
  {asin.pros && asin.pros.length > 0 && (
    <div class="rounded-2xl border border-emerald-100 bg-emerald-50/70 p-6">
      <h3 class="flex items-center gap-2 font-display text-lg font-semibold text-emerald-900">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">✓</span>
        What we like
      </h3>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-emerald-950">
        {asin.pros.map((pro) => (
          <li class="flex gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500" />
            <span>{pro}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
  {asin.cons && asin.cons.length > 0 && (
    <div class="rounded-2xl border border-rose-100 bg-rose-50/70 p-6">
      <h3 class="flex items-center gap-2 font-display text-lg font-semibold text-rose-900">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-rose-100 text-rose-700">!</span>
        What to consider
      </h3>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-rose-950">
        {asin.cons.map((con) => (
          <li class="flex gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-rose-400" />
            <span>{con}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>
