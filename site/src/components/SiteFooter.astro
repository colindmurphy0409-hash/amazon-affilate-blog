---
import { getAffiliateConfig } from '@/lib/affiliate';

const config = getAffiliateConfig();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="absolute inset-x-0 -mt-20 h-20 bg-gradient-to-b from-transparent to-brand-900/10 pointer-events-none" aria-hidden="true"></div>
  <div class="container-page py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-md">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-gold-400 via-brand-400 to-coral-400 text-sm font-bold text-white shadow-lg">
            WL
          </span>
          <span class="font-display text-xl font-semibold text-white">{config.site_name}</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-100/90">
          {config.site_tagline}. We research products carefully and only recommend picks we would stand behind.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-brand-50 ring-1 ring-white/20">Beauty</span>
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-brand-50 ring-1 ring-white/20">Fitness</span>
          <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-brand-50 ring-1 ring-white/20">Home</span>
        </div>
      </div>
      <div class="max-w-sm text-sm leading-relaxed text-brand-100/80">
        <p class="font-semibold text-white">Affiliate disclosure</p>
        <p class="mt-2 whitespace-pre-line">{config.disclosure_full}</p>
      </div>
    </div>
    <p class="mt-10 border-t border-white/10 pt-6 text-xs text-brand-200/70">
      © {year} {config.site_name}. All rights reserved.
    </p>
  </div>
</footer>
