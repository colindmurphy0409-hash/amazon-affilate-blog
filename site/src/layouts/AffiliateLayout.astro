---
import '@/styles/global.css';
import SEOHead from '@/components/SEOHead.astro';
import DisclosureBanner from '@/components/DisclosureBanner.astro';
import AmazonCTA from '@/components/AmazonCTA.astro';
import ProsCons from '@/components/ProsCons.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import StickyCTA from '@/components/StickyCTA.astro';
import ProductImage from '@/components/ProductImage.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import StarRating from '@/components/StarRating.astro';
import { getAffiliateConfig, getAsinDataList } from '@/lib/affiliate';

interface Props {
  title: string;
  description: string;
  type: 'review' | 'roundup' | 'comparison';
  slug: string;
  asins: string[];
  hero_cta_text?: string;
  verdict?: string;
  quick_pick_asin?: string;
  comparison_winner?: string;
  updated?: string;
}

const {
  title,
  description,
  type,
  slug,
  asins,
  hero_cta_text,
  verdict,
  quick_pick_asin,
  comparison_winner,
  updated,
} = Astro.props;

const config = getAffiliateConfig();
const asinData = getAsinDataList(asins);
const primaryAsin = asinData[0];
const quickPick = asinData.find((a) => a.asin === quick_pick_asin) ?? asinData[0];
const winner = asinData.find((a) => a.asin === comparison_winner) ?? asinData[0];
const stickyAsin = quickPick?.asin ?? primaryAsin?.asin ?? asins[0];

const typeLabels = {
  review: 'Product review',
  roundup: 'Buying guide',
  comparison: 'Head-to-head comparison',
} as const;
---

<!DOCTYPE html>
<html lang="en" translate="no">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <SEOHead
      title={title}
      description={description}
      type={type}
      slug={slug}
      asins={asinData}
      siteUrl={config.site_url}
    />
  </head>
  <body>
    <SiteHeader />

    <section class="border-b border-slate-200 bg-white">
      <div class="container-page py-10 md:py-14">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-ink-muted transition hover:text-brand-700">
          <span aria-hidden="true">←</span> Back to all guides
        </a>

        <div class="mt-6 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div>
            <span class="badge-type">{typeLabels[type]}</span>
            <h1 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-5xl">{title}</h1>
            <p class="mt-5 text-lg leading-relaxed text-ink-muted">{description}</p>
            {updated && (
              <p class="mt-4 text-sm text-ink-faint">Last updated {updated}</p>
            )}
          </div>

          {type === 'review' && primaryAsin && (
            <aside class="rounded-2xl border border-slate-200 bg-surface-muted p-6 shadow-card">
              <ProductImage asin={primaryAsin.asin} title={primaryAsin.title} size="hero" />
              <div class="mt-5 space-y-3">
                <p class="font-semibold text-ink">{primaryAsin.title}</p>
                <StarRating rating={primaryAsin.rating} reviewCount={primaryAsin.review_count} />
                {primaryAsin.price_band && (
                  <p class="text-sm text-ink-muted">Typical price: {primaryAsin.price_band}</p>
                )}
                {primaryAsin.best_for && (
                  <p class="text-sm leading-relaxed text-ink-muted">{primaryAsin.best_for}</p>
                )}
                <AmazonCTA asin={primaryAsin.asin} text={hero_cta_text ?? 'Check price on Amazon'} fullWidth />
              </div>
            </aside>
          )}

          {type === 'roundup' && quickPick && (
            <aside class="rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-6 shadow-card">
              <p class="text-xs font-bold uppercase tracking-wider text-brand-700">Our top pick</p>
              <div class="mt-4">
                <ProductImage asin={quickPick.asin} title={quickPick.title} size="hero" />
              </div>
              <p class="mt-5 font-display text-xl font-semibold text-ink">{quickPick.title}</p>
              {quickPick.best_for && <p class="mt-2 text-sm text-ink-muted">{quickPick.best_for}</p>}
              <div class="mt-4">
                <StarRating rating={quickPick.rating} reviewCount={quickPick.review_count} />
              </div>
              <div class="mt-5">
                <AmazonCTA asin={quickPick.asin} text={hero_cta_text ?? 'Check price on Amazon'} fullWidth />
              </div>
            </aside>
          )}

          {type === 'comparison' && asinData.length >= 2 && (
            <aside class="space-y-4">
              {asinData.slice(0, 2).map((asin, index) => (
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
                  <ProductImage asin={asin.asin} title={asin.title} size="card" />
                  <p class="mt-4 font-semibold text-ink">{asin.title}</p>
                  <div class="mt-2">
                    <StarRating rating={asin.rating} />
                  </div>
                  <div class="mt-4">
                    <AmazonCTA
                      asin={asin.asin}
                      text={`View ${asin.title.split(' ')[0]} on Amazon`}
                      variant={index === 0 ? 'primary' : 'secondary'}
                      fullWidth
                    />
                  </div>
                </div>
              ))}
            </aside>
          )}
        </div>
      </div>
    </section>

    <main class="container-page py-10 pb-28 md:pb-16">
      <DisclosureBanner />

      <article class="mx-auto max-w-3xl">
        {(type === 'roundup' || type === 'comparison') && asinData.length > 0 && (
          <ComparisonTable
            asins={asinData}
            highlightAsin={type === 'comparison' ? winner?.asin : quickPick?.asin}
          />
        )}

        <div class="prose-article">
          <slot />
        </div>

        {type === 'review' && primaryAsin && <ProsCons asin={primaryAsin} />}

        {verdict && (
          <div class="mt-12 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-900 to-slate-800 p-8 text-white shadow-lift">
            <h2 class="font-display text-2xl font-semibold text-white">Our verdict</h2>
            <p class="mt-4 text-base leading-relaxed text-slate-200">{verdict}</p>
            {primaryAsin && (
              <div class="mt-6">
                <AmazonCTA asin={stickyAsin} text="See current price on Amazon" variant="primary" />
              </div>
            )}
          </div>
        )}
      </article>
    </main>

    <SiteFooter />

    {stickyAsin && <StickyCTA asin={stickyAsin} text={hero_cta_text} />}
  </body>
</html>
