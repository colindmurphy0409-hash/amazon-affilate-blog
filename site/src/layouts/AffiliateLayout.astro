---
import '@/styles/global.css';
import SEOHead from '@/components/SEOHead.astro';
import DisclosureBanner from '@/components/DisclosureBanner.astro';
import AmazonCTA from '@/components/AmazonCTA.astro';
import ProsCons from '@/components/ProsCons.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import StickyCTA from '@/components/StickyCTA.astro';
import ProductCard from '@/components/ProductCard.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { getAffiliateConfig, getAsinDataList, nicheBadgeClass, nicheLabel } from '@/lib/affiliate';

interface Props {
  title: string;
  description: string;
  type: 'review' | 'roundup' | 'comparison';
  slug: string;
  asins: string[];
  hero_cta_text?: string;
  verdict?: string;
  quick_pick_asin?: string;
  comparison_winner?: string;
  updated?: string;
}

const {
  title,
  description,
  type,
  slug,
  asins,
  hero_cta_text,
  verdict,
  quick_pick_asin,
  comparison_winner,
  updated,
} = Astro.props;

const config = getAffiliateConfig();
const asinData = getAsinDataList(asins);
const primaryAsin = asinData[0];
const quickPick = asinData.find((a) => a.asin === quick_pick_asin) ?? asinData[0];
const winner = asinData.find((a) => a.asin === comparison_winner) ?? asinData[0];
const stickyAsin = quickPick?.asin ?? primaryAsin?.asin ?? asins[0];
const heroNiche = primaryAsin?.niche;

const typeLabels = {
  review: 'Product review',
  roundup: 'Buying guide',
  comparison: 'Head-to-head comparison',
} as const;
---

<!DOCTYPE html>
<html lang="en" translate="no">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <SEOHead
      title={title}
      description={description}
      type={type}
      slug={slug}
      asins={asinData}
      siteUrl={config.site_url}
    />
  </head>
  <body>
    <SiteHeader />

    <section class="relative overflow-hidden border-b border-brand-200/30 bg-mesh-hero">
      <div class="hero-blob -left-16 top-0 h-64 w-64 bg-brand-400/25" aria-hidden="true"></div>
      <div class="hero-blob right-0 top-8 h-48 w-48 bg-coral-400/20" aria-hidden="true"></div>
      <div class="hero-blob bottom-0 left-1/2 h-40 w-40 bg-gold-400/15" aria-hidden="true"></div>

      <svg class="pointer-events-none absolute right-12 top-20 hidden h-28 w-28 text-sage-400/30 lg:block" viewBox="0 0 100 100" fill="none" aria-hidden="true">
        <rect x="10" y="10" width="80" height="80" rx="20" stroke="currentColor" stroke-width="2" transform="rotate(12 50 50)" />
      </svg>

      <div class="container-page relative max-w-4xl py-10 md:py-14">
        <a href="/" class="inline-flex items-center gap-2 rounded-full bg-white/60 px-3 py-1.5 text-sm font-medium text-ink-muted ring-1 ring-white/80 backdrop-blur-sm transition hover:bg-white hover:text-brand-700">
          <span aria-hidden="true">←</span> Back to all guides
        </a>

        <div class="mt-6">
          <div class="flex flex-wrap items-center gap-2">
            {heroNiche && <span class={nicheBadgeClass(heroNiche)}>{nicheLabel(heroNiche)}</span>}
            <span class="badge-type">{typeLabels[type]}</span>
          </div>
          <h1 class="mt-4 font-display text-3xl font-semibold leading-tight text-ink md:text-4xl lg:text-5xl">{title}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-muted">{description}</p>
          {updated && (
            <p class="mt-4 text-sm text-ink-faint">Last updated {updated}</p>
          )}
        </div>

        {type === 'review' && primaryAsin && (
          <div class="mt-10">
            <ProductCard asin={primaryAsin} label="Product we tested" />
          </div>
        )}

        {type === 'roundup' && quickPick && (
          <div class="mt-10">
            <ProductCard asin={quickPick} label="Our top pick" highlighted />
          </div>
        )}

        {type === 'comparison' && asinData.length >= 2 && (
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            <ProductCard
              asin={asinData[0]}
              label={asinData[0].asin === winner?.asin ? 'Our pick' : 'Option A'}
              highlighted={asinData[0].asin === winner?.asin}
            />
            <ProductCard
              asin={asinData[1]}
              label={asinData[1].asin === winner?.asin ? 'Our pick' : 'Option B'}
              highlighted={asinData[1].asin === winner?.asin}
            />
          </div>
        )}
      </div>
    </section>

    <main class="container-page max-w-3xl py-10 pb-28 md:pb-16">
      <DisclosureBanner />

      <article>
        {type === 'roundup' && asinData.length > 0 && (
          <ComparisonTable asins={asinData} highlightAsin={quickPick?.asin} />
        )}

        <div class="prose-article">
          <slot />
        </div>

        {type === 'review' && primaryAsin && <ProsCons asin={primaryAsin} />}

        {type === 'comparison' && asinData.length >= 2 && (
          <div class="not-prose mt-12 grid gap-6 md:grid-cols-2">
            {asinData.map((asin) => (
              <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-card">
                <div class={asin.niche === 'beauty' ? 'card-strip-beauty -mx-5 -mt-5 mb-4 rounded-t-2xl' : asin.niche === 'fitness' ? 'card-strip-fitness -mx-5 -mt-5 mb-4 rounded-t-2xl' : 'card-strip-home -mx-5 -mt-5 mb-4 rounded-t-2xl'}></div>
                <h3 class="font-display text-lg font-semibold text-ink">{asin.title.split(',')[0]}</h3>
                {asin.pros && asin.pros.length > 0 && (
                  <ul class="mt-3 space-y-2 text-sm text-ink-muted">
                    {asin.pros.slice(0, 3).map((pro) => (
                      <li class="flex gap-2"><span class="text-brand-600">✓</span><span>{pro}</span></li>
                    ))}
                  </ul>
                )}
              </div>
            ))}
          </div>
        )}

        {verdict && (
          <div class="not-prose mt-12 rounded-2xl border border-brand-700/20 bg-gradient-to-br from-brand-900 via-brand-800 to-sage-700 p-8 text-white shadow-lift">
            <h2 class="font-display text-2xl font-semibold text-white">Our verdict</h2>
            <p class="mt-4 text-base leading-relaxed text-brand-100">{verdict}</p>
            <div class="mt-6">
              <AmazonCTA asin={stickyAsin} text={hero_cta_text ?? 'See current price on Amazon'} variant="primary" />
            </div>
          </div>
        )}
      </article>
    </main>

    <SiteFooter />

    {stickyAsin && <StickyCTA asin={stickyAsin} text={hero_cta_text} />}
  </body>
</html>
